<idea-plugin url="https://github.com/adam-kopec/local-review">
    <id>pl.archiprogram.localreview</id>
    <name>Local Review</name>
    <vendor email="adam.kopec@gmail.com" url="https://github.com/adam-kopec/local-review">Adam Kopeć</vendor>
    <!-- <description> and <change-notes> are injected at build time from README.md and
         CHANGELOG.md by the patchPluginXml task. Do not duplicate them here. -->

    <resource-bundle>messages.LocalReviewBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>
    <depends>com.intellij.mcpServer</depends>

    <extensions defaultExtensionNs="com.intellij.mcpServer">
        <mcpToolset implementation="pl.archiprogram.localreview.mcp.LocalReviewToolset"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="pl.archiprogram.localreview.hash.ContentHasher"/>
        <applicationService serviceInterface="pl.archiprogram.localreview.vcs.BranchProvider"
                            serviceImplementation="pl.archiprogram.localreview.vcs.DefaultBranchProvider"/>
        <applicationService serviceImplementation="pl.archiprogram.localreview.settings.LocalReviewSettings"/>

        <projectService serviceImplementation="pl.archiprogram.localreview.state.ReviewStateService"/>

        <postStartupActivity implementation="pl.archiprogram.localreview.startup.ReviewStartupActivity"/>

        <changesGroupingPolicy key="localreview.viewed"
                               implementationClass="pl.archiprogram.localreview.ui.ViewedGroupingPolicyFactory"/>

        <vcs.changes.changesViewModifier implementation="pl.archiprogram.localreview.ui.ReviewedChangesViewModifier"/>

        <postStartupActivity implementation="pl.archiprogram.localreview.ui.CommitViewRendererInstaller"/>

        <statusBarWidgetFactory id="pl.archiprogram.localreview.counter"
                                implementation="pl.archiprogram.localreview.ui.CounterWidgetFactory"/>

        <projectConfigurable parentId="tools"
                             id="pl.archiprogram.localreview.settings"
                             instance="pl.archiprogram.localreview.settings.LocalReviewConfigurable"
                             key="settings.title"/>

        <registryKey key="pl.archiprogram.localreview.trace"
                     defaultValue="false"
                     description="Enable Local Review debug trace logging"/>

        <notificationGroup id="LocalReview"
                           displayType="BALLOON"
                           bundle="messages.LocalReviewBundle"
                           key="notification.group.name"/>
    </extensions>

    <projectListeners>
        <listener class="pl.archiprogram.localreview.vcs.ChangeSetListener"
                  topic="com.intellij.openapi.vcs.changes.ChangeListListener"/>
        <listener class="pl.archiprogram.localreview.vcs.GitBranchListener"
                  topic="git4idea.repo.GitRepositoryChangeListener"/>
    </projectListeners>

    <actions resource-bundle="messages.LocalReviewBundle">
        <action id="LocalReview.ToggleViewed"
                class="pl.archiprogram.localreview.action.ToggleViewedAction"
                icon="pl.archiprogram.localreview.Icons.VIEWED">
            <keyboard-shortcut keymap="$default" first-keystroke="control alt shift V"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt shift V"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="first"/>
            <add-to-group group-id="ChangesViewToolbar" anchor="last"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="LocalReview.MarkAllViewed"
                class="pl.archiprogram.localreview.action.MarkAllViewedAction">
            <add-to-group group-id="ChangesViewPopupMenu"
                          anchor="after"
                          relative-to-action="LocalReview.ToggleViewed"/>
        </action>
        <action id="LocalReview.UnmarkAll"
                class="pl.archiprogram.localreview.action.UnmarkAllAction">
            <add-to-group group-id="ChangesViewPopupMenu"
                          anchor="after"
                          relative-to-action="LocalReview.MarkAllViewed"/>
        </action>
    </actions>
</idea-plugin>
